    {
      "parameters": {
        "sendTo": "={{ $json.customerEmail }}",
        "subject": "=Payment Reminder - Invoice #{{ $json.quoteNumber }} is Overdue",
        "message": "=<p>Dear Valued Customer,</p>\n\n<p>This is a friendly reminder that Invoice <strong>#{{ $json.quoteNumber }}</strong> is now overdue.</p>\n\n<h3>Invoice Details:</h3>\n<ul>\n  <li><strong>Invoice Number:</strong> {{ $json.quoteNumber }}</li>\n  <li><strong>Amount Due:</strong> ${{ $json.totalCost }}</li>\n  <li><strong>Due Date:</strong> {{ $json.dueDate }}</li>\n  <li><strong>Days Overdue:</strong> {{ $json.daysOverdue }}</li>\n</ul>\n\n<h3>Payment Instructions:</h3>\n<p>Please submit your payment at your earliest convenience using one of the following methods:</p>\n<ul>\n  <li>Bank Transfer: [Your Bank Details]</li>\n  <li>Check: Made payable to [Your Business Name]</li>\n  <li>Cash: In person at our office</li>\n</ul>\n\n<p>If you have already sent payment, please disregard this notice. If you have any questions or concerns about this invoice, please don't hesitate to contact us.</p>\n\n<p>Thank you for your prompt attention to this matter.</p>\n\n<p>Best regards,<br>\n[Your Business Name]<br>\n[Contact Information]</p>",
        "options": {}
      },
