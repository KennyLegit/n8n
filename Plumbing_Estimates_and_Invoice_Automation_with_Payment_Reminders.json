    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "// Get input data from webhook\nconst jobType = $input.item.json.body.jobType || 'General Plumbing';\nconst description = $input.item.json.body.description || '';\nconst laborHours = parseFloat($input.item.json.body.laborHours) || 0;\nconst materialCost = parseFloat($input.item.json.body.materialCost) || 0;\nconst isEmergency = $input.item.json.body.isEmergency === 'true' || $input.item.json.body.isEmergency === true;\nconst customerName = $input.item.json.body.customerName || '';\nconst customerEmail = $input.item.json.body.customerEmail || '';\n\n// Configuration from Workflow Configuration node\nconst laborRate = 85; // $ per hour\nconst taxRate = 0.08; // 8% tax\nconst emergencyFee = 150; // Emergency call-out fee\n\n// Calculate costs\nconst laborCost = laborHours * laborRate;\nconst emergencyCost = isEmergency ? emergencyFee : 0;\nconst subtotal = laborCost + materialCost + emergencyCost;\nconst taxAmount = subtotal * taxRate;\nconst totalCost = subtotal + taxAmount;\n\n// Generate quote number with timestamp\nconst timestamp = new Date().getTime();\nconst quoteNumber = `QUOTE-${timestamp}`;\nconst quoteDate = $today.toFormat('yyyy-MM-dd');\n\n// Return estimate data\nreturn {\n  quoteNumber: quoteNumber,\n  quoteDate: quoteDate,\n  customerName: customerName,\n  customerEmail: customerEmail,\n  jobType: jobType,\n  description: description,\n  laborHours: laborHours,\n  laborRate: laborRate,\n  laborCost: laborCost,\n  materialCost: materialCost,\n  isEmergency: isEmergency,\n  emergencyFee: emergencyCost,\n  subtotal: subtotal,\n  taxRate: taxRate,\n  taxAmount: taxAmount,\n  totalCost: totalCost\n};"
      },
