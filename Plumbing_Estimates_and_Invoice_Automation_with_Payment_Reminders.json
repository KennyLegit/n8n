    {
      "parameters": {
        "sendTo": "={{ $json.customerEmail }}",
        "subject": "={{ 'Your Plumbing Estimate - Quote #' + $json.quoteNumber }}",
        "message": "=<html>\n<head>\n  <style>\n    body { font-family: Arial, sans-serif; line-height: 1.6; color: #333; }\n    .container { max-width: 600px; margin: 0 auto; padding: 20px; }\n    .header { background-color: #2c5aa0; color: white; padding: 20px; text-align: center; }\n    .content { background-color: #f9f9f9; padding: 20px; margin-top: 20px; }\n    .quote-details { background-color: white; padding: 15px; margin: 15px 0; border-left: 4px solid #2c5aa0; }\n    .breakdown { margin: 20px 0; }\n    .breakdown-item { display: flex; justify-content: space-between; padding: 10px; border-bottom: 1px solid #ddd; }\n    .total { font-size: 1.2em; font-weight: bold; color: #2c5aa0; margin-top: 15px; padding-top: 15px; border-top: 2px solid #2c5aa0; }\n    .footer { text-align: center; margin-top: 30px; padding-top: 20px; border-top: 1px solid #ddd; color: #666; font-size: 0.9em; }\n  </style>\n</head>\n<body>\n  <div class=\"container\">\n    <div class=\"header\">\n      <h1>Plumbing Estimate</h1>\n      <p>Quote #{{ $json.quoteNumber }}</p>\n    </div>\n    \n    <div class=\"content\">\n      <p>Dear {{ $json.customerName }},</p>\n      \n      <p>Thank you for considering our plumbing services. Please find below your detailed estimate for the requested work.</p>\n      \n      <div class=\"quote-details\">\n        <h3>Project Details</h3>\n        <p><strong>Service Type:</strong> {{ $json.serviceType }}</p>\n        <p><strong>Description:</strong> {{ $json.description }}</p>\n        <p><strong>Estimated Date:</strong> {{ $json.estimatedDate }}</p>\n      </div>\n      \n      <div class=\"breakdown\">\n        <h3>Cost Breakdown</h3>\n        <div class=\"breakdown-item\">\n          <span>Labor</span>\n          <span>${{ $json.laborCost }}</span>\n        </div>\n        <div class=\"breakdown-item\">\n          <span>Materials</span>\n          <span>${{ $json.materialsCost }}</span>\n        </div>\n        <div class=\"breakdown-item\">\n          <span>Additional Fees</span>\n          <span>${{ $json.additionalFees }}</span>\n        </div>\n        <div class=\"total\">\n          <div class=\"breakdown-item\">\n            <span>Total Estimate</span>\n            <span>${{ $json.totalEstimate }}</span>\n          </div>\n        </div>\n      </div>\n      \n      <div class=\"quote-details\">\n        <h3>Payment Terms</h3>\n        <ul>\n          <li>50% deposit required to schedule work</li>\n          <li>Remaining balance due upon completion</li>\n          <li>Payment methods: Cash, Check, Credit Card</li>\n          <li>Estimate valid for 30 days</li>\n        </ul>\n      </div>\n      \n      <p>If you have any questions or would like to proceed with this estimate, please don't hesitate to contact us.</p>\n      \n      <p>We look forward to serving you!</p>\n      \n      <p>Best regards,<br>\n      Your Plumbing Team</p>\n    </div>\n    \n    <div class=\"footer\">\n      <p>This is an automated estimate. Please contact us to confirm and schedule your service.</p>\n    </div>\n  </div>\n</body>\n</html>",
        "options": {
          "appendAttribution": true
        }
      },
